{
  "name": "tax-invoice-manager",
  "version": "1.0.0",
  "description": "Professional offline Tax Invoice Manager - GST Invoice Software",
  "main": "electron/main.js",
  "homepage": "./",
  "author": "Your Company",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm start\" \"wait-on http://localhost:4200 && electron .\"",
    "electron-build": "npm run build:prod && electron .",
    "build-win": "npm run build:prod && electron-builder --win",
    "build-mac": "npm run build:prod && electron-builder --mac",
    "build-linux": "npm run build:prod && electron-builder --linux"
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@types/node": "^20.0.0",
    "concurrently": "^8.0.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.0.0",
    "electron-is-dev": "^2.0.0",
    "typescript": "^5.2.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.taxinvoicemanager.app",
    "productName": "Tax Invoice Manager",
    "files": [
      "electron/**",
      "dist/**"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}

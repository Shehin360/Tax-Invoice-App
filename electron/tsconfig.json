{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "module": "commonjs",
    "moduleResolution": "node",
    "types": ["node"],
    "target": "ES2020",
    "lib": ["ES2020"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "declaration": false,
    "skipLibCheck": true
  },
  "include": ["./**/*.ts", "./**/*.d.ts"],
  "exclude": ["./dist", "./node_modules"]
}
